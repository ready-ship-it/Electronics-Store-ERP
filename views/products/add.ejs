<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Product - Electronics Store ERP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        body { background-color: #f8f9fa; }
        .navbar-brand { font-weight: 600; }
        .card { border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.08); }
        .barcode-scan-btn { cursor: pointer; transition: all 0.2s; }
        .barcode-scan-btn:hover { background-color: #e9ecef; }
        #barcode-scanner-modal .modal-body { text-align: center; }
        #barcode-reader video { border-radius: 8px; width: 100% !important; }
        .scan-success { animation: pulse 0.5s ease; }
        @keyframes pulse { 0% { transform: scale(1); } 50% { transform: scale(1.05); } 100% { transform: scale(1); } }
        .input-group-text.barcode-icon { cursor: pointer; background-color: #ffc107; border-color: #ffc107; }
        .input-group-text.barcode-icon:hover { background-color: #ffca2c; }
        .autofilled { background-color: #e8f5e9 !important; border-color: #4caf50 !important; }
        .field-hint { font-size: 0.75rem; color: #4caf50; margin-top: 2px; display: none; }
        .field-hint.show { display: block; }
        .recent-scans { max-height: 200px; overflow-y: auto; }
        .scan-item { cursor: pointer; padding: 8px; border-radius: 6px; transition: background 0.2s; }
        .scan-item:hover { background-color: #f0f0f0; }
        .product-exists-alert { animation: slideDown 0.3s ease; }
        @keyframes slideDown { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
        .quick-fill-badge { font-size: 0.7rem; padding: 2px 6px; margin-left: 4px; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/"><i class="fas fa-store me-2"></i>Electronics Store ERP</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" href="/"><i class="fas fa-tachometer-alt me-1"></i>Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/products"><i class="fas fa-box me-1"></i>Products</a></li>
                    <li class="nav-item"><a class="nav-link" href="/products/scan"><i class="fas fa-barcode me-1"></i>Scanner</a></li>
                    <li class="nav-item"><a class="nav-link" href="/sales"><i class="fas fa-shopping-cart me-1"></i>Sales</a></li>
                    <li class="nav-item"><a class="nav-link" href="/reports"><i class="fas fa-chart-bar me-1"></i>Reports</a></li>
                </ul>
                <ul class="navbar-nav">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="fas fa-user-circle me-1"></i><%= user ? user.username : 'User' %>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="/users/profile"><i class="fas fa-user me-1"></i>Profile</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger" href="/auth/logout"><i class="fas fa-sign-out-alt me-1"></i>Logout</a></li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container py-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2><i class="fas fa-plus-circle me-2"></i>Add New Product</h2>
            <a href="/products" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Back to Products</a>
        </div>

        <% if (locals.success_msg && success_msg.length > 0) { %>
            <div class="alert alert-success alert-dismissible fade show">
                <%= success_msg %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>
        <% if (locals.error_msg && error_msg.length > 0) { %>
            <div class="alert alert-danger alert-dismissible fade show">
                <%= error_msg %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>

        <!-- Smart Scan Alert -->
        <div id="scan-alert-container"></div>

        <div class="row">
            <div class="col-lg-8">
                <div class="card">
                    <div class="card-body">
                        <form action="/products/add" method="POST" enctype="multipart/form-data" id="product-form">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                            <!-- Barcode Field with Scanner -->
                            <div class="mb-3">
                                <label class="form-label fw-bold"><i class="fas fa-barcode me-1"></i>Barcode</label>
                                <div class="input-group">
                                    <span class="input-group-text barcode-icon" id="barcode-icon-btn" title="Click to scan barcode">
                                        <i class="fas fa-barcode"></i>
                                    </span>
                                    <input type="text" name="barcode" id="barcode" class="form-control"
                                           placeholder="Scan or type barcode..." 
                                           value="<%= locals.query && query.barcode ? query.barcode : '' %>">
                                    <button type="button" class="btn btn-warning" id="scan-btn">
                                        <i class="fas fa-camera me-1"></i>Scan
                                    </button>
                                </div>
                                <small class="text-muted"><i class="fas fa-info-circle me-1"></i>Click the barcode icon or "Scan" button to use camera/USB scanner</small>
                            </div>

                            <!-- Basic Info -->
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Product Name *</label>
                                    <input type="text" name="name" id="name" class="form-control" required>
                                    <div class="field-hint" id="name-hint"><i class="fas fa-check me-1"></i>Auto-filled from database</div>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">SKU *</label>
                                    <input type="text" name="sku" id="sku" class="form-control" required>
                                    <div class="field-hint" id="sku-hint"><i class="fas fa-check me-1"></i>Auto-filled from database</div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Brand</label>
                                    <input type="text" name="brand" id="brand" class="form-control">
                                    <div class="field-hint" id="brand-hint"><i class="fas fa-check me-1"></i>Auto-filled from database</div>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Model</label>
                                    <input type="text" name="model" id="model" class="form-control">
                                    <div class="field-hint" id="model-hint"><i class="fas fa-check me-1"></i>Auto-filled from database</div>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Category</label>
                                <select name="category_id" id="category_id" class="form-select">
                                    <option value="">Select Category</option>
                                    <% if (locals.categories) { %>
                                        <% categories.forEach(cat => { %>
                                            <option value="<%= cat.id %>"><%= cat.name %></option>
                                        <% }); %>
                                    <% } %>
                                </select>
                                <div class="field-hint" id="category-hint"><i class="fas fa-check me-1"></i>Auto-filled from database</div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Description</label>
                                <textarea name="description" id="description" class="form-control" rows="3"></textarea>
                            </div>

                            <!-- HSN & GST -->
                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">HSN Code</label>
                                    <input type="text" name="hsn_code" id="hsn_code" class="form-control" placeholder="e.g. 8415">
                                    <div class="field-hint" id="hsn-hint"><i class="fas fa-check me-1"></i>Auto-filled from database</div>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">GST Rate (%)</label>
                                    <select name="gst_rate" id="gst_rate" class="form-select">
                                        <option value="5">5%</option>
                                        <option value="12">12%</option>
                                        <option value="18" selected>18%</option>
                                        <option value="28">28%</option>
                                    </select>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Unit</label>
                                    <select name="unit" id="unit" class="form-select">
                                        <option value="piece" selected>Piece</option>
                                        <option value="kg">KG</option>
                                        <option value="meter">Meter</option>
                                        <option value="box">Box</option>
                                    </select>
                                </div>
                            </div>

                            <!-- Pricing -->
                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Purchase Price *</label>
                                    <div class="input-group">
                                        <span class="input-group-text">&#8377;</span>
                                        <input type="number" name="purchase_price" id="purchase_price" class="form-control" step="0.01" required>
                                    </div>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Selling Price *</label>
                                    <div class="input-group">
                                        <span class="input-group-text">&#8377;</span>
                                        <input type="number" name="selling_price" id="selling_price" class="form-control" step="0.01" required>
                                    </div>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">MRP</label>
                                    <div class="input-group">
                                        <span class="input-group-text">&#8377;</span>
                                        <input type="number" name="mrp" id="mrp" class="form-control" step="0.01">
                                    </div>
                                </div>
                            </div>

                            <!-- Stock -->
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Initial Quantity</label>
                                    <input type="number" name="quantity" id="quantity" class="form-control" value="0" min="0">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Min Stock Alert</label>
                                    <input type="number" name="min_stock" id="min_stock" class="form-control" value="5" min="0">
                                </div>
                            </div>

                            <!-- Image -->
                            <div class="mb-3">
                                <label class="form-label">Product Image</label>
                                <input type="file" name="image" class="form-control" accept="image/*">
                            </div>

                            <!-- Specifications -->
                            <div class="mb-3">
                                <label class="form-label">Specifications (JSON format)</label>
                                <textarea name="specifications" id="specifications" class="form-control" rows="2" placeholder='{"color": "Black", "warranty": "1 Year"}'></textarea>
                            </div>

                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i>Save Product</button>
                                <button type="button" class="btn btn-outline-warning" id="clear-form-btn"><i class="fas fa-eraser me-1"></i>Clear Form</button>
                                <a href="/products" class="btn btn-outline-secondary">Cancel</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Sidebar -->
            <div class="col-lg-4">
                <!-- Quick Stats -->
                <div class="card border-primary mb-3">
                    <div class="card-header bg-primary text-white"><i class="fas fa-database me-1"></i>Your Database</div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span>Products Saved</span>
                            <span class="badge bg-primary" id="db-product-count">Loading...</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span>Barcodes Tracked</span>
                            <span class="badge bg-success" id="db-barcode-count">Loading...</span>
                        </div>
                    </div>
                </div>

                <!-- Recent Scans -->
                <div class="card border-info mb-3">
                    <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                        <span><i class="fas fa-history me-1"></i>Recent Scans</span>
                        <button class="btn btn-sm btn-light" id="clear-history-btn"><i class="fas fa-trash"></i></button>
                    </div>
                    <div class="card-body p-0">
                        <div id="recent-scans-list" class="recent-scans p-2">
                            <div class="text-center text-muted py-3">
                                <i class="fas fa-barcode fa-2x mb-2"></i>
                                <p class="mb-0 small">No scans yet</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Quick Tips -->
                <div class="card border-warning">
                    <div class="card-header bg-warning text-dark"><i class="fas fa-lightbulb me-1"></i>Quick Tips</div>
                    <div class="card-body">
                        <ul class="list-unstyled mb-0 small">
                            <li class="mb-2"><i class="fas fa-barcode me-1 text-warning"></i>Scan barcode to auto-fill product details</li>
                            <li class="mb-2"><i class="fas fa-file-invoice me-1 text-primary"></i>HSN code is required for GST invoices</li>
                            <li class="mb-2"><i class="fas fa-boxes me-1 text-success"></i>Set min stock to get low stock alerts</li>
                            <li><i class="fas fa-tag me-1 text-danger"></i>MRP should be higher than selling price</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Barcode Scanner Modal -->
    <div class="modal fade" id="barcode-scanner-modal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="fas fa-barcode me-2"></i>Scan Barcode</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <div id="barcode-reader" style="width: 100%; min-height: 300px;"></div>
                        <div id="modal-scanner-status" class="mt-2">
                            <span class="badge bg-secondary">Click Start to begin scanning</span>
                        </div>
                    </div>
                    <div class="d-flex gap-2 justify-content-center">
                        <button id="modal-start-scan" class="btn btn-success"><i class="fas fa-play me-1"></i>Start Camera</button>
                        <button id="modal-stop-scan" class="btn btn-danger" disabled><i class="fas fa-stop me-1"></i>Stop</button>
                    </div>
                    <hr>
                    <div class="alert alert-info mb-0">
                        <i class="fas fa-usb me-1"></i><strong>USB Scanner:</strong> You can also use your USB barcode scanner directly. Just scan while this modal is open!
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
    <script>
        // ==================== CONFIGURATION ====================
        const CONFIG = {
            USB_SCAN_TIMEOUT: 100,
            RECENT_SCANS_MAX: 20,
            API_ENDPOINTS: {
                lookup: '/products/lookup-barcode/',
                stats: '/api/products/stats'
            }
        };

        // ==================== STATE ====================
        let modalHtml5QrCode = null;
        let modalIsScanning = false;
        let usbBarcodeBuffer = '';
        let usbLastKeyTime = 0;
        let recentScans = JSON.parse(localStorage.getItem('recentScans') || '[]');

        // ==================== DOM ELEMENTS ====================
        const modalScanner = document.getElementById('barcode-scanner-modal');
        const modalStatus = document.getElementById('modal-scanner-status');
        const modalStartBtn = document.getElementById('modal-start-scan');
        const modalStopBtn = document.getElementById('modal-stop-scan');
        const scanAlertContainer = document.getElementById('scan-alert-container');

        // ==================== INITIALIZATION ====================
        document.addEventListener('DOMContentLoaded', function() {
            initEventListeners();
            loadDatabaseStats();
            renderRecentScans();
        });

        function initEventListeners() {
            // Scanner buttons
            document.getElementById('barcode-icon-btn').addEventListener('click', openBarcodeModal);
            document.getElementById('scan-btn').addEventListener('click', openBarcodeModal);
            if (modalStartBtn) modalStartBtn.addEventListener('click', startModalScanner);
            if (modalStopBtn) modalStopBtn.addEventListener('click', stopModalScanner);

            // Form buttons
            document.getElementById('clear-form-btn').addEventListener('click', clearForm);
            document.getElementById('clear-history-btn').addEventListener('click', clearScanHistory);

            // USB scanner
            document.addEventListener('keydown', handleUSBScanner);

            // Modal cleanup
            if (modalScanner) {
                modalScanner.addEventListener('hidden.bs.modal', function() {
                    if (modalIsScanning) stopModalScanner();
                });
            }
        }

        // ==================== CAMERA SCANNER ====================
        function openBarcodeModal() {
            try {
                if (typeof bootstrap === 'undefined') {
                    showAlert('Bootstrap not loaded. Please check your internet connection.', 'danger');
                    return;
                }
                const modal = new bootstrap.Modal(modalScanner);
                modal.show();
            } catch (err) {
                console.error('Modal open error:', err);
                showAlert('Could not open scanner: ' + err.message, 'danger');
            }
        }

        function startModalScanner() {
            if (modalIsScanning) return;
            if (typeof Html5Qrcode === 'undefined') {
                modalStatus.innerHTML = '<span class="badge bg-danger">Scanner library not loaded. Refresh the page.</span>';
                return;
            }

            modalHtml5QrCode = new Html5Qrcode("barcode-reader");
            const config = {
                fps: 10,
                qrbox: { width: 250, height: 250 },
                aspectRatio: 1.0,
                formatsToSupport: [
                    Html5QrcodeSupportedFormats.EAN_13,
                    Html5QrcodeSupportedFormats.EAN_8,
                    Html5QrcodeSupportedFormats.UPC_A,
                    Html5QrcodeSupportedFormats.UPC_E,
                    Html5QrcodeSupportedFormats.CODE_128,
                    Html5QrcodeSupportedFormats.CODE_39,
                    Html5QrcodeSupportedFormats.ITF,
                    Html5QrcodeSupportedFormats.QR_CODE
                ]
            };

            modalHtml5QrCode.start(
                { facingMode: "environment" },
                config,
                onModalScanSuccess,
                onModalScanFailure
            ).then(() => {
                modalIsScanning = true;
                modalStartBtn.disabled = true;
                modalStopBtn.disabled = false;
                modalStatus.innerHTML = '<span class="badge bg-success"><i class="fas fa-video me-1"></i>Scanning...</span>';
            }).catch(err => {
                console.error('Camera scanner error:', err);
                modalStatus.innerHTML = '<span class="badge bg-danger">Camera Error: ' + err.message + '</span>';
            });
        }

        function stopModalScanner() {
            if (!modalHtml5QrCode || !modalIsScanning) return;
            modalHtml5QrCode.stop().then(() => {
                modalIsScanning = false;
                modalStartBtn.disabled = false;
                modalStopBtn.disabled = true;
                modalStatus.innerHTML = '<span class="badge bg-secondary">Stopped</span>';
                modalHtml5QrCode.clear();
                modalHtml5QrCode = null;
            }).catch(err => console.error('Stop error:', err));
        }

        function onModalScanSuccess(decodedText, decodedResult) {
            stopModalScanner();
            closeModal();
            processBarcode(decodedText, 'camera');
        }

        function onModalScanFailure(error) { /* ignore continuous scan failures */ }

        function closeModal() {
            try {
                const modalInstance = bootstrap.Modal.getInstance(modalScanner);
                if (modalInstance) modalInstance.hide();
            } catch (e) { console.error('Modal hide error:', e); }
        }

        // ==================== USB SCANNER ====================
        function handleUSBScanner(e) {
            const now = Date.now();
            const timeDiff = now - usbLastKeyTime;
            if (timeDiff > CONFIG.USB_SCAN_TIMEOUT && usbBarcodeBuffer.length > 0) {
                usbBarcodeBuffer = '';
            }
            usbLastKeyTime = now;

            if (e.ctrlKey || e.altKey || e.metaKey) return;

            if (e.code === 'Enter') {
                if (usbBarcodeBuffer.length >= 3) {
                    e.preventDefault();
                    const barcode = usbBarcodeBuffer;
                    usbBarcodeBuffer = '';
                    processBarcode(barcode, 'usb');
                }
                return;
            }

            if (e.key.length !== 1) return;
            usbBarcodeBuffer += e.key;
        }

        // ==================== SMART AUTO-FILL ====================
        function processBarcode(barcode, source) {
            if (!barcode || barcode.trim() === '') return;
            barcode = barcode.trim();

            // Update barcode field
            const barcodeField = document.getElementById('barcode');
            if (barcodeField) {
                barcodeField.value = barcode;
                barcodeField.classList.add('scan-success');
                setTimeout(() => barcodeField.classList.remove('scan-success'), 500);
            }

            playBeep();
            addToRecentScans(barcode, source);

            // Lookup in database
            lookupBarcode(barcode);
        }

        function lookupBarcode(barcode) {
            showAlert('<i class="fas fa-spinner fa-spin me-1"></i>Looking up barcode...', 'info', false);

            fetch(CONFIG.API_ENDPOINTS.lookup + encodeURIComponent(barcode))
                .then(res => res.json())
                .then(data => {
                    clearAlerts();
                    if (data.success && data.product) {
                        // Product exists - auto-fill all fields
                        autoFillForm(data.product);
                        showProductExistsWarning(data.product);
                        addToRecentScans(barcode, 'db-found', data.product.name);
                    } else {
                        // New product - just confirm barcode captured
                        showNewProductPrompt(barcode);
                        addToRecentScans(barcode, 'db-new');
                    }
                })
                .catch(err => {
                    console.error('Barcode lookup error:', err);
                    clearAlerts();
                    showAlert('Error looking up barcode. You can still enter details manually.', 'warning');
                });
        }

        function autoFillForm(product) {
            const fields = {
                'name': product.name,
                'sku': product.sku,
                'brand': product.brand,
                'model': product.model,
                'hsn_code': product.hsn_code,
                'description': product.description,
                'purchase_price': product.purchase_price,
                'selling_price': product.selling_price,
                'mrp': product.mrp,
                'quantity': product.quantity || 0,
                'min_stock': product.min_stock || 5
            };

            // Fill text inputs
            Object.keys(fields).forEach(fieldId => {
                const element = document.getElementById(fieldId);
                if (element && fields[fieldId]) {
                    element.value = fields[fieldId];
                    element.classList.add('autofilled');
                    showFieldHint(fieldId);
                }
            });

            // Fill select fields
            if (product.category_id) {
                const categorySelect = document.getElementById('category_id');
                if (categorySelect) {
                    categorySelect.value = product.category_id;
                    categorySelect.classList.add('autofilled');
                    showFieldHint('category');
                }
            }

            if (product.gst_rate) {
                const gstSelect = document.getElementById('gst_rate');
                if (gstSelect) gstSelect.value = product.gst_rate;
            }

            if (product.unit) {
                const unitSelect = document.getElementById('unit');
                if (unitSelect) unitSelect.value = product.unit;
            }

            // Specifications
            if (product.specifications) {
                const specField = document.getElementById('specifications');
                if (specField) {
                    try {
                        const specs = typeof product.specifications === 'string' 
                            ? product.specifications 
                            : JSON.stringify(product.specifications, null, 2);
                        specField.value = specs;
                    } catch (e) {}
                }
            }
        }

        function showFieldHint(fieldId) {
            const hint = document.getElementById(fieldId + '-hint');
            if (hint) hint.classList.add('show');
        }

        function hideAllFieldHints() {
            document.querySelectorAll('.field-hint').forEach(hint => hint.classList.remove('show'));
        }

        function showProductExistsWarning(product) {
            const html = `
                <div class="alert alert-warning alert-dismissible fade show product-exists-alert">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    <strong>Product already exists in your database!</strong>
                    <div class="mt-2">
                        <strong>${product.name}</strong> <span class="badge bg-secondary">${product.sku}</span>
                        <br><small>Brand: ${product.brand || 'N/A'} | Category: ${product.category_name || 'N/A'}</small>
                    </div>
                    <div class="mt-2">
                        <a href="/products/${product.id}/edit" class="btn btn-sm btn-primary me-1">
                            <i class="fas fa-edit me-1"></i>Edit Product
                        </a>
                        <a href="/products/${product.id}" class="btn btn-sm btn-info me-1">
                            <i class="fas fa-eye me-1"></i>View Details
                        </a>
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="clearForm()">
                            <i class="fas fa-plus me-1"></i>Add as New
                        </button>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            `;
            scanAlertContainer.innerHTML = html;
        }

        function showNewProductPrompt(barcode) {
            const html = `
                <div class="alert alert-success alert-dismissible fade show product-exists-alert">
                    <i class="fas fa-check-circle me-2"></i>
                    <strong>New barcode captured!</strong>
                    <p class="mb-1 mt-1">Barcode <code>${barcode}</code> not found in your database.</p>
                    <p class="mb-0 small text-muted">Fill in the product details below and click Save.</p>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            `;
            scanAlertContainer.innerHTML = html;
        }

        // ==================== RECENT SCANS ====================
        function addToRecentScans(barcode, source, productName) {
            const scan = {
                barcode: barcode,
                source: source,
                productName: productName || null,
                timestamp: new Date().toISOString()
            };

            // Remove duplicates
            recentScans = recentScans.filter(s => s.barcode !== barcode);
            recentScans.unshift(scan);
            if (recentScans.length > CONFIG.RECENT_SCANS_MAX) {
                recentScans = recentScans.slice(0, CONFIG.RECENT_SCANS_MAX);
            }

            localStorage.setItem('recentScans', JSON.stringify(recentScans));
            renderRecentScans();
        }

        function renderRecentScans() {
            const container = document.getElementById('recent-scans-list');
            if (!recentScans.length) {
                container.innerHTML = `
                    <div class="text-center text-muted py-3">
                        <i class="fas fa-barcode fa-2x mb-2"></i>
                        <p class="mb-0 small">No scans yet</p>
                    </div>
                `;
                return;
            }

            const sourceIcons = {
                'camera': '<i class="fas fa-camera text-primary"></i>',
                'usb': '<i class="fas fa-usb text-warning"></i>',
                'db-found': '<i class="fas fa-database text-success"></i>',
                'db-new': '<i class="fas fa-plus-circle text-info"></i>'
            };

            const html = recentScans.map(scan => {
                const time = new Date(scan.timestamp).toLocaleTimeString();
                const icon = sourceIcons[scan.source] || sourceIcons['camera'];
                const name = scan.productName ? `<div class="small text-success">${scan.productName}</div>` : '';
                const badge = scan.source === 'db-found' 
                    ? '<span class="badge bg-success quick-fill-badge">Found</span>' 
                    : '<span class="badge bg-info quick-fill-badge">New</span>';

                return `
                    <div class="scan-item d-flex justify-content-between align-items-center" onclick="quickFillBarcode('${scan.barcode}')">
                        <div>
                            <div class="font-monospace small">${scan.barcode} ${badge}</div>
                            ${name}
                        </div>
                        <div class="text-muted small">
                            ${icon}
                            <span class="ms-1">${time}</span>
                        </div>
                    </div>
                `;
            }).join('');

            container.innerHTML = html;
        }

        function quickFillBarcode(barcode) {
            processBarcode(barcode, 'manual');
        }

        function clearScanHistory() {
            recentScans = [];
            localStorage.removeItem('recentScans');
            renderRecentScans();
        }

        // ==================== DATABASE STATS ====================
        function loadDatabaseStats() {
            fetch(CONFIG.API_ENDPOINTS.stats)
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        document.getElementById('db-product-count').textContent = data.totalProducts || 0;
                        document.getElementById('db-barcode-count').textContent = data.totalBarcodes || 0;
                    }
                })
                .catch(err => {
                    console.error('Stats load error:', err);
                    document.getElementById('db-product-count').textContent = '?';
                    document.getElementById('db-barcode-count').textContent = '?';
                });
        }

        // ==================== FORM UTILITIES ====================
        function clearForm() {
            document.getElementById('product-form').reset();
            hideAllFieldHints();
            clearAlerts();

            // Remove autofilled classes
            document.querySelectorAll('.autofilled').forEach(el => el.classList.remove('autofilled'));

            // Reset defaults
            document.getElementById('gst_rate').value = '18';
            document.getElementById('unit').value = 'piece';
            document.getElementById('quantity').value = '0';
            document.getElementById('min_stock').value = '5';

            // Focus barcode field
            document.getElementById('barcode').focus();
        }

        function showAlert(message, type, autoDismiss = true) {
            const html = `
                <div class="alert alert-${type} alert-dismissible fade show product-exists-alert">
                    ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            `;
            scanAlertContainer.innerHTML = html;

            if (autoDismiss && type !== 'danger') {
                setTimeout(() => {
                    const alert = scanAlertContainer.querySelector('.alert');
                    if (alert) {
                        const bsAlert = new bootstrap.Alert(alert);
                        bsAlert.close();
                    }
                }, 5000);
            }
        }

        function clearAlerts() {
            scanAlertContainer.innerHTML = '';
        }

        // ==================== AUDIO FEEDBACK ====================
        function playBeep() {
            try {
                const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                const oscillator = audioCtx.createOscillator();
                const gainNode = audioCtx.createGain();
                oscillator.connect(gainNode);
                gainNode.connect(audioCtx.destination);
                oscillator.frequency.value = 800;
                oscillator.type = 'sine';
                gainNode.gain.value = 0.1;
                oscillator.start();
                oscillator.stop(audioCtx.currentTime + 0.1);
            } catch (e) {}
        }
    </script>
</body>
</html>
