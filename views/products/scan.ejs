<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Barcode Scanner - Electronics Store ERP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        body { background-color: #f8f9fa; }
        .navbar-brand { font-weight: 600; }
        #reader video { border-radius: 8px; width: 100% !important; }
        #reader__dashboard_section_csr span { display: none !important; }
        #reader__dashboard_section_swaplink { display: none !important; }
        #usb-barcode-input { font-family: monospace; font-size: 1.1rem; }
        .scan-card { border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.08); }
        .product-found-card { border-left: 4px solid #198754; }
        .product-not-found-card { border-left: 4px solid #ffc107; }
    </style>
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">
                <i class="fas fa-store me-2"></i>Electronics Store ERP
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/"><i class="fas fa-tachometer-alt me-1"></i>Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/products"><i class="fas fa-box me-1"></i>Products</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="/products/scan"><i class="fas fa-barcode me-1"></i>Barcode Scanner</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/sales"><i class="fas fa-shopping-cart me-1"></i>Sales</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/reports"><i class="fas fa-chart-bar me-1"></i>Reports</a>
                    </li>
                </ul>
                <ul class="navbar-nav">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="fas fa-user-circle me-1"></i><%= user ? user.username : 'User' %>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="/users/profile"><i class="fas fa-user me-1"></i>Profile</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger" href="/auth/logout"><i class="fas fa-sign-out-alt me-1"></i>Logout</a></li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container-fluid py-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2><i class="fas fa-barcode me-2"></i>Barcode Scanner</h2>
            <a href="/products" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-1"></i>Back to Products
            </a>
        </div>

        <% if (locals.success_msg && success_msg.length > 0) { %>
            <div class="alert alert-success alert-dismissible fade show">
                <%= success_msg %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>
        <% if (locals.error_msg && error_msg.length > 0) { %>
            <div class="alert alert-danger alert-dismissible fade show">
                <%= error_msg %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>

        <div class="row">
            <!-- Scanner Panel -->
            <div class="col-lg-6 mb-4">
                <!-- Camera Scanner Card -->
                <div class="card scan-card mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="fas fa-camera me-2"></i>Camera Scanner</h5>
                    </div>
                    <div class="card-body">
                        <div id="scanner-container" class="text-center">
                            <div id="reader" style="width: 100%; min-height: 300px;"></div>
                            <div id="scanner-status" class="mt-2">
                                <span class="badge bg-secondary">Initializing...</span>
                            </div>
                        </div>
                        <div class="mt-3 d-flex gap-2 justify-content-center">
                            <button id="start-scan" class="btn btn-success">
                                <i class="fas fa-play me-1"></i>Start Camera
                            </button>
                            <button id="stop-scan" class="btn btn-danger" disabled>
                                <i class="fas fa-stop me-1"></i>Stop
                            </button>
                        </div>
                    </div>
                </div>

                <!-- USB Barcode Scanner Card -->
                <div class="card scan-card border-warning">
                    <div class="card-header bg-warning text-dark">
                        <h5 class="mb-0"><i class="fas fa-usb me-2"></i>USB Barcode Scanner</h5>
                    </div>
                    <div class="card-body">
                        <div class="alert alert-info mb-3">
                            <i class="fas fa-info-circle me-1"></i>
                            <strong>How it works:</strong> Your USB scanner acts like a keyboard.
                            Just scan any barcode while this page is open — it will be captured automatically.
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <div class="flex-grow-1">
                                <div class="input-group">
                                    <span class="input-group-text bg-warning"><i class="fas fa-barcode"></i></span>
                                    <input type="text" id="usb-barcode-input" class="form-control"
                                           placeholder="Click here, then scan with USB scanner..."
                                           autocomplete="off">
                                </div>
                            </div>
                            <div id="usb-scanner-status">
                                <span class="badge bg-secondary">Standby</span>
                            </div>
                        </div>
                        <small class="text-muted mt-2 d-block">
                            <i class="fas fa-lightbulb me-1"></i>
                            Tip: Most USB scanners auto-send Enter after scanning. If not, configure it via your scanner manual.
                        </small>
                    </div>
                </div>
            </div>

            <!-- Scan Results Panel -->
            <div class="col-lg-6 mb-4">
                <div class="card scan-card">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0"><i class="fas fa-search me-2"></i>Scan Results</h5>
                    </div>
                    <div class="card-body">
                        <!-- Manual Barcode Entry -->
                        <div class="mb-4">
                            <label class="form-label fw-bold">Or Enter Barcode Manually:</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-keyboard"></i></span>
                                <input type="text" id="manual-barcode" class="form-control"
                                       placeholder="Type barcode and press Enter..." autofocus>
                                <button class="btn btn-primary" id="lookup-btn">
                                    <i class="fas fa-search me-1"></i>Lookup
                                </button>
                            </div>
                        </div>

                        <!-- Product Found -->
                        <div id="product-found" class="d-none">
                            <div class="alert alert-success">
                                <h6 class="alert-heading"><i class="fas fa-check-circle me-1"></i>Product Found!</h6>
                            </div>
                            <div class="card product-found-card">
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-4 text-center">
                                            <img id="product-image" src="" alt="Product"
                                                 class="img-fluid rounded" style="max-height: 150px;"
                                                 onerror="this.src='/images/no-image.png'">
                                        </div>
                                        <div class="col-md-8">
                                            <h5 id="product-name" class="card-title"></h5>
                                            <p id="product-brand" class="text-muted mb-1"></p>
                                            <p id="product-sku" class="text-muted mb-1 font-monospace small"></p>
                                            <p id="product-barcode" class="text-muted mb-2 font-monospace small"></p>
                                            <div class="d-flex gap-2 mb-2">
                                                <span class="badge bg-info" id="product-hsn"></span>
                                                <span class="badge bg-warning text-dark" id="product-gst"></span>
                                            </div>
                                            <h4 class="text-primary mb-0">&#8377;<span id="product-price"></span></h4>
                                            <p class="text-muted small">MRP: &#8377;<span id="product-mrp"></span></p>
                                            <p class="mb-0">
                                                <span class="badge bg-secondary" id="product-stock"></span>
                                            </p>
                                        </div>
                                    </div>
                                    <hr>
                                    <div class="d-flex gap-2 flex-wrap">
                                        <a id="edit-product-btn" href="#" class="btn btn-warning btn-sm">
                                            <i class="fas fa-edit me-1"></i>Edit Product
                                        </a>
                                        <a id="add-stock-btn" href="#" class="btn btn-info btn-sm">
                                            <i class="fas fa-plus me-1"></i>Add Stock
                                        </a>
                                        <a id="new-sale-btn" href="#" class="btn btn-success btn-sm">
                                            <i class="fas fa-shopping-cart me-1"></i>New Sale
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Product Not Found -->
                        <div id="product-not-found" class="d-none">
                            <div class="alert alert-warning">
                                <h6 class="alert-heading"><i class="fas fa-exclamation-triangle me-1"></i>Product Not Found</h6>
                                <p class="mb-0">No product found with barcode: <strong id="not-found-barcode"></strong></p>
                            </div>
                            <div class="d-grid gap-2">
                                <a id="add-product-btn" href="/products/new" class="btn btn-primary">
                                    <i class="fas fa-plus me-1"></i>Add New Product with this Barcode
                                </a>
                                <button class="btn btn-outline-secondary" onclick="clearResults()">
                                    <i class="fas fa-redo me-1"></i>Scan Another
                                </button>
                            </div>
                        </div>

                        <!-- Scan History -->
                        <div class="mt-4">
                            <h6 class="fw-bold"><i class="fas fa-history me-1"></i>Recent Scans</h6>
                            <div id="scan-history" class="list-group list-group-flush">
                                <div class="list-group-item text-muted text-center py-3">
                                    No scans yet. Use camera, USB scanner, or manual entry!
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
    <script>
// ==================== CAMERA SCANNER ====================
let html5QrCode = null;
let isScanning = false;

const scannerStatus = document.getElementById('scanner-status');
const startBtn = document.getElementById('start-scan');
const stopBtn = document.getElementById('stop-scan');

startBtn.addEventListener('click', startCameraScanner);
stopBtn.addEventListener('click', stopCameraScanner);

function startCameraScanner() {
    if (isScanning) return;

    html5QrCode = new Html5Qrcode("reader");

    const config = {
        fps: 10,
        qrbox: { width: 250, height: 250 },
        aspectRatio: 1.0,
        formatsToSupport: [
            Html5QrcodeSupportedFormats.EAN_13,
            Html5QrcodeSupportedFormats.EAN_8,
            Html5QrcodeSupportedFormats.UPC_A,
            Html5QrcodeSupportedFormats.UPC_E,
            Html5QrcodeSupportedFormats.CODE_128,
            Html5QrcodeSupportedFormats.CODE_39,
            Html5QrcodeSupportedFormats.ITF,
            Html5QrcodeSupportedFormats.QR_CODE
        ]
    };

    html5QrCode.start(
        { facingMode: "environment" },
        config,
        onCameraScanSuccess,
        onCameraScanFailure
    ).then(() => {
        isScanning = true;
        startBtn.disabled = true;
        stopBtn.disabled = false;
        scannerStatus.innerHTML = '<span class="badge bg-success"><i class="fas fa-video me-1"></i>Camera Scanning...</span>';
    }).catch(err => {
        console.error('Camera scanner error:', err);
        scannerStatus.innerHTML = '<span class="badge bg-danger"><i class="fas fa-times me-1"></i>Camera Error: ' + err.message + '</span>';
    });
}

function stopCameraScanner() {
    if (!html5QrCode || !isScanning) return;

    html5QrCode.stop().then(() => {
        isScanning = false;
        startBtn.disabled = false;
        stopBtn.disabled = true;
        scannerStatus.innerHTML = '<span class="badge bg-secondary">Camera Stopped</span>';
        html5QrCode.clear();
        html5QrCode = null;
    }).catch(err => {
        console.error('Stop camera error:', err);
    });
}

function onCameraScanSuccess(decodedText, decodedResult) {
    stopCameraScanner();
    document.getElementById('manual-barcode').value = decodedText;
    lookupBarcode(decodedText, 'camera');
    playBeep();
}

function onCameraScanFailure(error) {
    // Ignore continuous scan failures
}

// ==================== USB BARCODE SCANNER (HID Keyboard Mode) ====================
let usbBarcodeBuffer = '';
let usbLastKeyTime = 0;
const USB_SCAN_TIMEOUT = 100;
const usbScannerStatus = document.getElementById('usb-scanner-status');
const usbInputField = document.getElementById('usb-barcode-input');

// Method 1: Global keyboard listener
document.addEventListener('keydown', function(e) {
    const now = Date.now();
    const timeDiff = now - usbLastKeyTime;

    if (timeDiff > USB_SCAN_TIMEOUT && usbBarcodeBuffer.length > 0) {
        usbBarcodeBuffer = '';
    }

    usbLastKeyTime = now;

    if (e.ctrlKey || e.altKey || e.metaKey) return;

    if (e.code === 'Enter') {
        if (usbBarcodeBuffer.length >= 3) {
            e.preventDefault();
            handleUSBBarcode(usbBarcodeBuffer);
            usbBarcodeBuffer = '';
        }
        return;
    }

    if (e.key.length !== 1) return;

    usbBarcodeBuffer += e.key;

    usbScannerStatus.innerHTML = '<span class="badge bg-warning text-dark"><i class="fas fa-spinner fa-spin me-1"></i>Scanning...</span>';

    clearTimeout(window.usbScanTimeout);
    window.usbScanTimeout = setTimeout(() => {
        if (usbBarcodeBuffer.length > 0) {
            usbBarcodeBuffer = '';
            usbScannerStatus.innerHTML = '<span class="badge bg-secondary">Standby</span>';
        }
    }, USB_SCAN_TIMEOUT + 50);
});

// Method 2: Input field listener
usbInputField.addEventListener('input', function(e) {
    const value = this.value.trim();
    if (value.length >= 8) {
        clearTimeout(window.usbInputTimeout);
        window.usbInputTimeout = setTimeout(() => {
            if (this.value.trim() === value) {
                handleUSBBarcode(value);
                this.value = '';
            }
        }, 150);
    }
});

usbInputField.addEventListener('keydown', function(e) {
    if (e.code === 'Enter') {
        e.preventDefault();
        const value = this.value.trim();
        if (value.length >= 3) {
            handleUSBBarcode(value);
            this.value = '';
        }
    }
});

function handleUSBBarcode(barcode) {
    console.log('USB Scanner detected:', barcode);
    usbScannerStatus.innerHTML = '<span class="badge bg-success"><i class="fas fa-check me-1"></i>USB Scan: ' + barcode.substring(0, 15) + (barcode.length > 15 ? '...' : '') + '</span>';

    document.getElementById('manual-barcode').value = barcode;
    lookupBarcode(barcode, 'usb');
    playBeep();

    setTimeout(() => {
        usbScannerStatus.innerHTML = '<span class="badge bg-secondary">Standby</span>';
    }, 3000);
}

// ==================== MANUAL LOOKUP ====================
document.getElementById('lookup-btn').addEventListener('click', function() {
    const barcode = document.getElementById('manual-barcode').value.trim();
    if (barcode) lookupBarcode(barcode, 'manual');
});

document.getElementById('manual-barcode').addEventListener('keypress', function(e) {
    if (e.key === 'Enter') {
        const barcode = this.value.trim();
        if (barcode) lookupBarcode(barcode, 'manual');
    }
});

// ==================== LOOKUP API ====================
function lookupBarcode(barcode, source) {
    if (!barcode || barcode.trim() === '') {
        alert('Please enter or scan a barcode');
        return;
    }

    barcode = barcode.trim();

    document.getElementById('product-found').classList.add('d-none');
    document.getElementById('product-not-found').classList.add('d-none');

    fetch('/products/lookup-barcode/' + encodeURIComponent(barcode))
        .then(res => res.json())
        .then(data => {
            if (data.success && data.product) {
                showProduct(data.product);
                addToHistory(barcode, data.product.name, true, source);
            } else {
                showNotFound(barcode);
                addToHistory(barcode, null, false, source);
            }
        })
        .catch(err => {
            console.error('Lookup error:', err);
            alert('Error looking up product. Please try again.');
        });
}

function showProduct(product) {
    document.getElementById('product-found').classList.remove('d-none');
    document.getElementById('product-not-found').classList.add('d-none');

    document.getElementById('product-name').textContent = product.name;
    document.getElementById('product-brand').textContent = product.brand || 'No Brand';
    document.getElementById('product-sku').textContent = 'SKU: ' + product.sku;
    document.getElementById('product-barcode').textContent = 'Barcode: ' + product.barcode;
    document.getElementById('product-hsn').textContent = 'HSN: ' + (product.hsn_code || 'N/A');
    document.getElementById('product-gst').textContent = 'GST: ' + (product.gst_rate || 18) + '%';
    document.getElementById('product-price').textContent = product.selling_price;
    document.getElementById('product-mrp').textContent = product.mrp || product.selling_price;

    const stockBadge = document.getElementById('product-stock');
    stockBadge.textContent = 'Stock: ' + product.quantity + ' units';
    if (product.quantity <= product.min_stock) {
        stockBadge.className = 'badge bg-danger';
        stockBadge.textContent += ' (Low!)';
    } else if (product.quantity === 0) {
        stockBadge.className = 'badge bg-dark';
        stockBadge.textContent = 'Out of Stock';
    } else {
        stockBadge.className = 'badge bg-success';
    }

    document.getElementById('product-image').src = product.image || '/images/no-image.png';
    document.getElementById('edit-product-btn').href = '/products/' + product.id + '/edit';
    document.getElementById('add-stock-btn').href = '/products/' + product.id + '/stock';
    document.getElementById('new-sale-btn').href = '/sales/new?product=' + product.id;
}

function showNotFound(barcode) {
    document.getElementById('product-found').classList.add('d-none');
    document.getElementById('product-not-found').classList.remove('d-none');
    document.getElementById('not-found-barcode').textContent = barcode;
    document.getElementById('add-product-btn').href = '/products/new?barcode=' + encodeURIComponent(barcode);
}

function clearResults() {
    document.getElementById('product-found').classList.add('d-none');
    document.getElementById('product-not-found').classList.add('d-none');
    document.getElementById('manual-barcode').value = '';
    document.getElementById('manual-barcode').focus();
}

// ==================== SCAN HISTORY ====================
let scanHistory = [];

function addToHistory(barcode, name, found, source) {
    const historyDiv = document.getElementById('scan-history');

    if (scanHistory.length === 0) {
        historyDiv.innerHTML = '';
    }

    scanHistory.unshift({ barcode, name, found, source, time: new Date().toLocaleTimeString() });
    if (scanHistory.length > 10) scanHistory.pop();

    const sourceIcon = {
        'camera': '<i class="fas fa-camera text-primary"></i>',
        'usb': '<i class="fas fa-usb text-warning"></i>',
        'manual': '<i class="fas fa-keyboard text-secondary"></i>'
    };

    const item = document.createElement('div');
    item.className = 'list-group-item d-flex justify-content-between align-items-center';
    item.innerHTML = `
        <div>
            <small class="font-monospace">${barcode}</small>
            ${sourceIcon[source] || sourceIcon['manual']}
            ${name ? `<div class="small text-success">${name}</div>` : '<div class="small text-danger">Not Found</div>'}
        </div>
        <span class="badge bg-light text-dark">${new Date().toLocaleTimeString()}</span>
    `;

    historyDiv.insertBefore(item, historyDiv.firstChild);
}

// ==================== AUDIO FEEDBACK ====================
function playBeep() {
    try {
        const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        const oscillator = audioCtx.createOscillator();
        const gainNode = audioCtx.createGain();

        oscillator.connect(gainNode);
        gainNode.connect(audioCtx.destination);

        oscillator.frequency.value = 800;
        oscillator.type = 'sine';
        gainNode.gain.value = 0.1;

        oscillator.start();
        oscillator.stop(audioCtx.currentTime + 0.1);
    } catch (e) {
        // Audio not supported
    }
}

// ==================== INITIALIZATION ====================
window.addEventListener('load', () => {
    Html5Qrcode.getCameras().then(cameras => {
        if (cameras && cameras.length > 0) {
            scannerStatus.innerHTML = '<span class="badge bg-info"><i class="fas fa-camera me-1"></i>' + cameras.length + ' camera(s) found. Click Start Camera.</span>';
        } else {
            scannerStatus.innerHTML = '<span class="badge bg-warning text-dark"><i class="fas fa-exclamation-triangle me-1"></i>No cameras found. Use USB scanner or manual entry.</span>';
        }
    }).catch(err => {
        scannerStatus.innerHTML = '<span class="badge bg-warning text-dark"><i class="fas fa-exclamation-triangle me-1"></i>Camera access denied or not available</span>';
    });

    // Focus the USB input field for immediate scanning
    usbInputField.focus();
});

// Keep USB input focused when clicking elsewhere
document.addEventListener('click', function(e) {
    if (e.target.tagName === 'BUTTON' || e.target.tagName === 'A' || e.target.closest('button') || e.target.closest('a')) {
        return;
    }
    setTimeout(() => usbInputField.focus(), 100);
});
    </script>
</body>
</html>
