<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="mb-1">Reports & Analytics</h5>
        <p class="text-muted mb-0" style="font-size: 13px;">Comprehensive business insights</p>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <a href="/reports/daily" class="card text-decoration-none h-100">
            <div class="card-body text-center">
                <div class="stat-icon blue mx-auto"><i class="fas fa-calendar-day"></i></div>
                <h6 class="mt-2">Daily Report</h6>
                <p class="text-muted mb-0" style="font-size: 12px;">View today's sales with PDF export</p>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="/reports/monthly" class="card text-decoration-none h-100">
            <div class="card-body text-center">
                <div class="stat-icon green mx-auto"><i class="fas fa-calendar-alt"></i></div>
                <h6 class="mt-2">Monthly Report</h6>
                <p class="text-muted mb-0" style="font-size: 12px;">Monthly sales analysis with charts</p>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="/reports/yearly" class="card text-decoration-none h-100">
            <div class="card-body text-center">
                <div class="stat-icon purple mx-auto"><i class="fas fa-calendar"></i></div>
                <h6 class="mt-2">Yearly Report</h6>
                <p class="text-muted mb-0" style="font-size: 12px;">Annual performance overview</p>
            </div>
        </a>
    </div>

    <div class="col-lg-6">
        <div class="card">
            <div class="card-header"><h5><i class="fas fa-trophy me-2 text-warning"></i>Top Selling Products</h5></div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table">
                        <thead><tr><th>Product</th><th>Brand</th><th>Sold</th><th>Revenue</th></tr></thead>
                        <tbody>
                            <% topProducts.forEach(p => { %>
                            <tr>
                                <td><%= p.name %></td>
                                <td><%= p.brand || '-' %></td>
                                <td><%= p.total_sold %></td>
                                <td class="fw-medium">₹<%= parseFloat(p.total_revenue).toLocaleString('en-IN', {minimumFractionDigits: 2}) %></td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card">
            <div class="card-header"><h5><i class="fas fa-chart-pie me-2 text-info"></i>Sales by Category</h5></div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table">
                        <thead><tr><th>Category</th><th>Sales</th><th>Revenue</th></tr></thead>
                        <tbody>
                            <% categorySales.forEach(c => { %>
                            <tr>
                                <td><%= c.name || 'Uncategorized' %></td>
                                <td><%= c.sales_count %></td>
                                <td class="fw-medium">₹<%= parseFloat(c.revenue).toLocaleString('en-IN', {minimumFractionDigits: 2}) %></td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>