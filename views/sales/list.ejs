<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="mb-1">Sales</h5>
        <p class="text-muted mb-0" style="font-size: 13px;">Manage invoices and transactions</p>
    </div>
    <a href="/sales/new" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i>New Sale
    </a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form method="GET" class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label" style="font-size: 12px;">From Date</label>
                <input type="date" name="start_date" class="form-control" value="<%= filters.start_date || '' %>">
            </div>
            <div class="col-md-3">
                <label class="form-label" style="font-size: 12px;">To Date</label>
                <input type="date" name="end_date" class="form-control" value="<%= filters.end_date || '' %>">
            </div>
            <div class="col-md-4">
                <label class="form-label" style="font-size: 12px;">Customer</label>
                <input type="text" name="customer" class="form-control" placeholder="Customer name" value="<%= filters.customer || '' %>">
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100"><i class="fas fa-filter me-1"></i>Filter</button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Invoice #</th><th>Customer</th><th>Contact</th><th>Subtotal</th><th>GST</th><th>Discount</th><th>Total</th><th>Payment</th><th>Status</th><th>Date</th><th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% sales.forEach(sale => { %>
                    <tr>
                        <td><span class="fw-medium text-primary"><%= sale.invoice_number %></span></td>
                        <td><%= sale.customer_name %></td>
                        <td><%= sale.customer_phone || '-' %></td>
                        <td>₹<%= parseFloat(sale.subtotal).toLocaleString('en-IN', {minimumFractionDigits: 2}) %></td>
                        <td>₹<%= parseFloat(sale.gst_amount).toLocaleString('en-IN', {minimumFractionDigits: 2}) %></td>
                        <td>₹<%= parseFloat(sale.discount).toLocaleString('en-IN', {minimumFractionDigits: 2}) %></td>
                        <td class="fw-bold">₹<%= parseFloat(sale.total_amount).toLocaleString('en-IN', {minimumFractionDigits: 2}) %></td>
                        <td><span class="badge bg-light text-dark border"><%= sale.payment_method.toUpperCase() %></span></td>
                        <td><span class="status-badge status-<%= sale.payment_status %>"><%= sale.payment_status.toUpperCase() %></span></td>
                        <td><%= new Date(sale.created_at).toLocaleDateString('en-IN') %></td>
                        <td>
                            <a href="/sales/invoice/<%= sale.id %>" class="btn btn-sm btn-light" title="View Invoice"><i class="fas fa-eye"></i></a>
                            <a href="/sales/invoice/<%= sale.id %>/pdf" class="btn btn-sm btn-light" title="Download PDF"><i class="fas fa-file-pdf"></i></a>
                        </td>
                    </tr>
                    <% }) %>
                    <% if (sales.length === 0) { %>
                    <tr><td colspan="11" class="text-center text-muted py-5">
                        <i class="fas fa-receipt fa-2x mb-2 d-block"></i>
                        No sales found. <a href="/sales/new">Create your first sale</a>
                    </td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>