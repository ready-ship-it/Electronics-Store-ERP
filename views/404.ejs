<!DOCTYPE html>
<html>
<head>
    <title>404 - Page Not Found</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { display: flex; align-items: center; justify-content: center; min-height: 100vh; background: #f1f5f9; }
        .error-box { text-align: center; padding: 40px; }
        .error-code { font-size: 120px; font-weight: 700; color: #2563eb; line-height: 1; }
    </style>
</head>
<body>
    <div class="error-box">
        <div class="error-code">404</div>
        <h3 class="mb-3">Page Not Found</h3>
        <p class="text-muted mb-4">The page you're looking for doesn't exist.</p>
        <a href="/" class="btn btn-primary"><i class="fas fa-home me-2"></i>Go to Dashboard</a>
    </div>
</body>
</html>