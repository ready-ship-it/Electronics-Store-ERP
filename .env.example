# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=electronics_store

# Session Secret
SESSION_SECRET=your_super_secret_key_here_change_this_in_production

# Application Port
PORT=3000
NODE_ENV=development

# FTP Backup Configuration (Optional)
FTP_HOST=ftp.example.com
FTP_USER=ftp_username
FTP_PASSWORD=ftp_password
FTP_BACKUP_PATH=/backups/

# Railway Production (set these in Railway dashboard)
# MYSQL_URL=mysql://user:pass@host:3306/dbname
# PORT=3000
# NODE_ENV=production
# SESSION_SECRET=your_production_secret
