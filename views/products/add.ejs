<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Product - Electronics Store ERP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        body { background-color: #f8f9fa; }
        .navbar-brand { font-weight: 600; }
        .card { border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.08); }
        .barcode-scan-btn {
            cursor: pointer;
            transition: all 0.2s;
        }
        .barcode-scan-btn:hover {
            background-color: #e9ecef;
        }
        #barcode-scanner-modal .modal-body {
            text-align: center;
        }
        #barcode-reader video {
            border-radius: 8px;
            width: 100% !important;
        }
        .scan-success {
            animation: pulse 0.5s ease;
        }
        @keyframes pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.05); }
            100% { transform: scale(1); }
        }
        .input-group-text.barcode-icon {
            cursor: pointer;
            background-color: #ffc107;
            border-color: #ffc107;
        }
        .input-group-text.barcode-icon:hover {
            background-color: #ffca2c;
        }
    </style>
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">
                <i class="fas fa-store me-2"></i>Electronics Store ERP
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" href="/"><i class="fas fa-tachometer-alt me-1"></i>Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/products"><i class="fas fa-box me-1"></i>Products</a></li>
                    <li class="nav-item"><a class="nav-link" href="/products/scan"><i class="fas fa-barcode me-1"></i>Scanner</a></li>
                    <li class="nav-item"><a class="nav-link" href="/sales"><i class="fas fa-shopping-cart me-1"></i>Sales</a></li>
                    <li class="nav-item"><a class="nav-link" href="/reports"><i class="fas fa-chart-bar me-1"></i>Reports</a></li>
                </ul>
                <ul class="navbar-nav">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="fas fa-user-circle me-1"></i><%= user ? user.username : 'User' %>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="/users/profile"><i class="fas fa-user me-1"></i>Profile</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger" href="/auth/logout"><i class="fas fa-sign-out-alt me-1"></i>Logout</a></li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container py-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2><i class="fas fa-plus-circle me-2"></i>Add New Product</h2>
            <a href="/products" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-1"></i>Back to Products
            </a>
        </div>

        <% if (locals.success_msg && success_msg.length > 0) { %>
            <div class="alert alert-success alert-dismissible fade show">
                <%= success_msg %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>
        <% if (locals.error_msg && error_msg.length > 0) { %>
            <div class="alert alert-danger alert-dismissible fade show">
                <%= error_msg %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>

        <div class="row">
            <div class="col-lg-8">
                <div class="card">
                    <div class="card-body">
                        <form action="/products/add" method="POST" enctype="multipart/form-data">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                            <!-- Barcode Field with Scanner -->
                            <div class="mb-3">
                                <label class="form-label fw-bold">
                                    <i class="fas fa-barcode me-1"></i>Barcode
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text barcode-icon" id="barcode-icon-btn" title="Click to scan barcode">
    <i class="fas fa-barcode"></i>
</span>
                                    <input type="text" name="barcode" id="barcode" class="form-control"
                                           placeholder="Scan or type barcode..." 
                                           value="<%= locals.query && query.barcode ? query.barcode : '' %>">
                                    <button type="button" class="btn btn-warning" id="scan-btn">
    <i class="fas fa-camera me-1"></i>Scan
</button>
                                </div>
                                <small class="text-muted">
                                    <i class="fas fa-info-circle me-1"></i>
                                    Click the barcode icon or "Scan" button to use camera/USB scanner
                                </small>
                            </div>

                            <!-- Basic Info -->
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Product Name *</label>
                                    <input type="text" name="name" class="form-control" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">SKU *</label>
                                    <input type="text" name="sku" class="form-control" required>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Brand</label>
                                    <input type="text" name="brand" class="form-control">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Model</label>
                                    <input type="text" name="model" class="form-control">
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Category</label>
                                <select name="category_id" class="form-select">
                                    <option value="">Select Category</option>
                                    <% if (locals.categories) { %>
                                        <% categories.forEach(cat => { %>
                                            <option value="<%= cat.id %>"><%= cat.name %></option>
                                        <% }); %>
                                    <% } %>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Description</label>
                                <textarea name="description" class="form-control" rows="3"></textarea>
                            </div>

                            <!-- HSN & GST -->
                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">HSN Code</label>
                                    <input type="text" name="hsn_code" class="form-control" placeholder="e.g. 8415">
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">GST Rate (%)</label>
                                    <select name="gst_rate" class="form-select">
                                        <option value="5">5%</option>
                                        <option value="12">12%</option>
                                        <option value="18" selected>18%</option>
                                        <option value="28">28%</option>
                                    </select>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Unit</label>
                                    <select name="unit" class="form-select">
                                        <option value="piece" selected>Piece</option>
                                        <option value="kg">KG</option>
                                        <option value="litre">Litre</option>
                                        <option value="meter">Meter</option>
                                    </select>
                                </div>
                            </div>

                            <!-- Pricing -->
                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Purchase Price (&#8377;) *</label>
                                    <input type="number" name="purchase_price" class="form-control" step="0.01" required>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Selling Price (&#8377;) *</label>
                                    <input type="number" name="selling_price" class="form-control" step="0.01" required>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">MRP (&#8377;)</label>
                                    <input type="number" name="mrp" class="form-control" step="0.01">
                                </div>
                            </div>

                            <!-- Stock -->
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Initial Quantity</label>
                                    <input type="number" name="quantity" class="form-control" value="0">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Min Stock Alert</label>
                                    <input type="number" name="min_stock" class="form-control" value="5">
                                </div>
                            </div>

                            <!-- Image -->
                            <div class="mb-3">
                                <label class="form-label">Product Image</label>
                                <input type="file" name="image" class="form-control" accept="image/*">
                            </div>

                            <!-- Specifications -->
                            <div class="mb-3">
                                <label class="form-label">Specifications (JSON)</label>
                                <textarea name="specifications" class="form-control" rows="3" 
                                    placeholder='{"capacity":"1.5 Ton","star_rating":"5 Star"}'></textarea>
                            </div>

                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-save me-1"></i>Save Product
                                </button>
                                <a href="/products" class="btn btn-outline-secondary">Cancel</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Sidebar: Quick Tips -->
            <div class="col-lg-4">
                <div class="card mb-3">
                    <div class="card-header bg-info text-white">
                        <h6 class="mb-0"><i class="fas fa-lightbulb me-1"></i>Quick Tips</h6>
                    </div>
                    <div class="card-body">
                        <ul class="list-unstyled mb-0 small">
                            <li class="mb-2"><i class="fas fa-barcode text-warning me-1"></i>Use the barcode scanner to auto-fill product data</li>
                            <li class="mb-2"><i class="fas fa-tag text-info me-1"></i>HSN code is required for GST invoices</li>
                            <li class="mb-2"><i class="fas fa-box text-success me-1"></i>Set min stock to get low stock alerts</li>
                            <li><i class="fas fa-rupee-sign text-primary me-1"></i>MRP should be higher than selling price</li>
                        </ul>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header bg-warning text-dark">
                        <h6 class="mb-0"><i class="fas fa-keyboard me-1"></i>USB Scanner</h6>
                    </div>
                    <div class="card-body">
                        <p class="small mb-2">Just click the barcode field and scan — the barcode will be captured automatically!</p>
                        <div class="alert alert-light border small mb-0">
                            <i class="fas fa-info-circle me-1"></i>
                            Make sure your USB scanner sends Enter after each scan.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Barcode Scanner Modal -->
    <div class="modal fade" id="barcode-scanner-modal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="fas fa-barcode me-2"></i>Scan Barcode</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <div id="barcode-reader" style="width: 100%; min-height: 300px;"></div>
                        <div id="modal-scanner-status" class="mt-2">
                            <span class="badge bg-secondary">Click Start to begin scanning</span>
                        </div>
                    </div>
                    <div class="d-flex gap-2 justify-content-center">
                        <button id="modal-start-scan" class="btn btn-success">
                            <i class="fas fa-play me-1"></i>Start Camera
                        </button>
                        <button id="modal-stop-scan" class="btn btn-danger" disabled>
                            <i class="fas fa-stop me-1"></i>Stop
                        </button>
                    </div>
                    <hr>
                    <div class="alert alert-info mb-0">
                        <i class="fas fa-usb me-1"></i>
                        <strong>USB Scanner:</strong> You can also use your USB barcode scanner directly.
                        Just scan while this modal is open — the barcode will be captured automatically!
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
	document.getElementById('barcode-icon-btn').addEventListener('click', openBarcodeModal);
document.getElementById('scan-btn').addEventListener('click', openBarcodeModal);
    <script>
        // ==================== BARCODE SCANNER MODAL ====================
        let modalHtml5QrCode = null;
    let modalIsScanning = false;
    const modalScanner = document.getElementById('barcode-scanner-modal');
    const modalStatus = document.getElementById('modal-scanner-status');
    const modalStartBtn = document.getElementById('modal-start-scan');
    const modalStopBtn = document.getElementById('modal-stop-scan');

    function openBarcodeModal() {
        try {
            if (typeof bootstrap === 'undefined') {
                alert('Bootstrap not loaded. Please check your internet connection and refresh the page.');
                return;
            }
            const modal = new bootstrap.Modal(modalScanner);
            modal.show();
        } catch (err) {
            console.error('Modal open error:', err);
            alert('Could not open scanner: ' + err.message);
        }
    }

    if (modalStartBtn) {
        modalStartBtn.addEventListener('click', startModalScanner);
    }
    if (modalStopBtn) {
        modalStopBtn.addEventListener('click', stopModalScanner);
    }

    function startModalScanner() {
        if (modalIsScanning) return;

        // Check if library is loaded
        if (typeof Html5Qrcode === 'undefined') {
            modalStatus.innerHTML = '<span class="badge bg-danger">Scanner library not loaded. Please refresh the page.</span>';
            console.error('Html5Qrcode is not defined. Check if html5-qrcode.min.js loaded correctly.');
            return;
        }

        modalHtml5QrCode = new Html5Qrcode("barcode-reader");

        const config = {
            fps: 10,
            qrbox: { width: 250, height: 250 },
            aspectRatio: 1.0,
            formatsToSupport: [
                Html5QrcodeSupportedFormats.EAN_13,
                Html5QrcodeSupportedFormats.EAN_8,
                Html5QrcodeSupportedFormats.UPC_A,
                Html5QrcodeSupportedFormats.UPC_E,
                Html5QrcodeSupportedFormats.CODE_128,
                Html5QrcodeSupportedFormats.CODE_39,
                Html5QrcodeSupportedFormats.ITF,
                Html5QrcodeSupportedFormats.QR_CODE
            ]
        };

        modalHtml5QrCode.start(
            { facingMode: "environment" },
            config,
            onModalScanSuccess,
            onModalScanFailure
        ).then(() => {
            modalIsScanning = true;
            modalStartBtn.disabled = true;
            modalStopBtn.disabled = false;
            modalStatus.innerHTML = '<span class="badge bg-success"><i class="fas fa-video me-1"></i>Scanning...</span>';
        }).catch(err => {
            console.error('Camera scanner error:', err);
            modalStatus.innerHTML = '<span class="badge bg-danger">Camera Error: ' + err.message + '</span>';
        });
    }

    function stopModalScanner() {
        if (!modalHtml5QrCode || !modalIsScanning) return;

        modalHtml5QrCode.stop().then(() => {
            modalIsScanning = false;
            modalStartBtn.disabled = false;
            modalStopBtn.disabled = true;
            modalStatus.innerHTML = '<span class="badge bg-secondary">Stopped</span>';
            modalHtml5QrCode.clear();
            modalHtml5QrCode = null;
        }).catch(err => console.error('Stop error:', err));
    }

    function onModalScanSuccess(decodedText, decodedResult) {
        stopModalScanner();
        document.getElementById('barcode').value = decodedText;
        document.getElementById('barcode').classList.add('scan-success');
        setTimeout(() => document.getElementById('barcode').classList.remove('scan-success'), 500);

        // Close modal safely
        try {
            const modalInstance = bootstrap.Modal.getInstance(modalScanner);
            if (modalInstance) modalInstance.hide();
        } catch (e) {
            console.error('Modal hide error:', e);
        }

        playBeep();
        checkBarcodeExists(decodedText);
    }

    function onModalScanFailure(error) {
        // Ignore continuous scan failures
    }

        // ==================== USB SCANNER (Global Capture) ====================
    let usbBarcodeBuffer = '';
    let usbLastKeyTime = 0;
    const USB_SCAN_TIMEOUT = 100;

    document.addEventListener('keydown', function(e) {
        const now = Date.now();
        const timeDiff = now - usbLastKeyTime;

        if (timeDiff > USB_SCAN_TIMEOUT && usbBarcodeBuffer.length > 0) {
            usbBarcodeBuffer = '';
        }

        usbLastKeyTime = now;

        if (e.ctrlKey || e.altKey || e.metaKey) return;

        if (e.code === 'Enter') {
            if (usbBarcodeBuffer.length >= 3) {
                e.preventDefault();
                const barcode = usbBarcodeBuffer;
                usbBarcodeBuffer = '';

                const barcodeField = document.getElementById('barcode');
                if (barcodeField) {
                    barcodeField.value = barcode;
                    barcodeField.classList.add('scan-success');
                    setTimeout(() => barcodeField.classList.remove('scan-success'), 500);
                }

                playBeep();
                checkBarcodeExists(barcode);
            }
            return;
        }

        if (e.key.length !== 1) return;
        usbBarcodeBuffer += e.key;
    });

         // ==================== CHECK IF BARCODE EXISTS ====================
    function checkBarcodeExists(barcode) {
        fetch('/products/lookup-barcode/' + encodeURIComponent(barcode))
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    const barcodeField = document.getElementById('barcode');
                    if (barcodeField) barcodeField.classList.add('is-valid');

                    const alertDiv = document.createElement('div');
                    alertDiv.className = 'alert alert-warning alert-dismissible fade show mt-2';
                    alertDiv.innerHTML = `
                        <i class="fas fa-exclamation-triangle me-1"></i>
                        <strong>Product already exists!</strong> 
                        "${data.product.name}" is already in database. 
                        <a href="/products/${data.product.id}/edit" class="alert-link">Edit it</a> 
                        or <a href="/products/${data.product.id}" class="alert-link">view details</a>.
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    `;
                    if (barcodeField && barcodeField.parentElement && barcodeField.parentElement.parentElement) {
                        barcodeField.parentElement.parentElement.appendChild(alertDiv);
                    }
                } else {
                    const barcodeField = document.getElementById('barcode');
                    if (barcodeField) barcodeField.classList.add('is-valid');
                }
            })
            .catch(err => console.error('Barcode check error:', err));
    }

    // ==================== AUDIO FEEDBACK ====================
    function playBeep() {
        try {
            const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            const oscillator = audioCtx.createOscillator();
            const gainNode = audioCtx.createGain();
            oscillator.connect(gainNode);
            gainNode.connect(audioCtx.destination);
            oscillator.frequency.value = 800;
            oscillator.type = 'sine';
            gainNode.gain.value = 0.1;
            oscillator.start();
            oscillator.stop(audioCtx.currentTime + 0.1);
        } catch (e) {}
    }

    // ==================== MODAL CLEANUP ====================
    if (modalScanner) {
        modalScanner.addEventListener('hidden.bs.modal', function () {
            if (modalIsScanning) {
                stopModalScanner();
            }
        });
    }
</script>
</body>
</html>
