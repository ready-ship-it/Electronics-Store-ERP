<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="mb-1">Daily Sales Report</h5>
        <p class="text-muted mb-0" style="font-size: 13px;"><%= new Date(reportDate).toLocaleDateString('en-IN', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></p>
    </div>
    <div class="d-flex gap-2">
        <form method="GET" class="d-flex gap-2">
            <input type="date" name="date" class="form-control" value="<%= reportDate %>" onchange="this.form.submit()">
        </form>
        <a href="/reports/daily/pdf?date=<%= reportDate %>" class="btn btn-danger"><i class="fas fa-file-pdf me-2"></i>PDF</a>
        <button onclick="printPage()" class="btn btn-primary"><i class="fas fa-print me-2"></i>Print</button>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-icon blue"><i class="fas fa-receipt"></i></div>
            <div class="stat-value"><%= summary.total_invoices || 0 %></div>
            <div class="stat-label">Total Invoices</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-icon green"><i class="fas fa-rupee-sign"></i></div>
            <div class="stat-value">₹<%= (summary.total_revenue || 0).toLocaleString('en-IN', {minimumFractionDigits: 2}) %></div>
            <div class="stat-label">Total Revenue</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-icon purple"><i class="fas fa-percentage"></i></div>
            <div class="stat-value">₹<%= (summary.total_gst || 0).toLocaleString('en-IN', {minimumFractionDigits: 2}) %></div>
            <div class="stat-label">Total GST</div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr><th>Invoice #</th><th>Customer</th><th>Subtotal</th><th>GST</th><th>Discount</th><th>Total</th><th>Payment</th><th>Status</th><th>Time</th></tr>
                </thead>
                <tbody>
                    <% sales.forEach(sale => { %>
                    <tr>
                        <td><%= sale.invoice_number %></td>
                        <td><%= sale.customer_name %></td>
                        <td>₹<%= parseFloat(sale.subtotal).toLocaleString('en-IN', {minimumFractionDigits: 2}) %></td>
                        <td>₹<%= parseFloat(sale.gst_amount).toLocaleString('en-IN', {minimumFractionDigits: 2}) %></td>
                        <td>₹<%= parseFloat(sale.discount).toLocaleString('en-IN', {minimumFractionDigits: 2}) %></td>
                        <td class="fw-bold">₹<%= parseFloat(sale.total_amount).toLocaleString('en-IN', {minimumFractionDigits: 2}) %></td>
                        <td><%= sale.payment_method.toUpperCase() %></td>
                        <td><span class="status-badge status-<%= sale.payment_status %>"><%= sale.payment_status.toUpperCase() %></span></td>
                        <td><%= new Date(sale.created_at).toLocaleTimeString('en-IN') %></td>
                    </tr>
                    <% }) %>
                    <% if (sales.length === 0) { %>
                    <tr><td colspan="9" class="text-center text-muted py-5">No sales for this date</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>