<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="mb-1"><i class="fas fa-eye me-2"></i>Product Details</h5>
        <p class="text-muted mb-0" style="font-size: 13px;">View complete product information</p>
    </div>
    <div class="d-flex gap-2">
        <a href="/products" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Back to Products
        </a>
        <% if (user.role === 'master_admin' || user.role === 'admin') { %>
        <a href="/products/edit/<%= product.id %>" class="btn btn-primary">
            <i class="fas fa-edit me-2"></i>Edit Product
        </a>
        <% } %>
    </div>
</div>

<div class="row">
    <!-- Product Image & Basic Info -->
    <div class="col-lg-4 mb-4">
        <div class="card">
            <div class="card-body text-center">
                <% if (product.image) { %>
                <img src="<%= product.image %>" class="img-fluid rounded mb-3" alt="<%= product.name %>" style="max-height: 250px; object-fit: contain;">
                <% } else { %>
                <div class="bg-light rounded d-flex align-items-center justify-content-center mb-3" style="height: 250px;">
                    <i class="fas fa-image fa-4x text-muted"></i>
                </div>
                <% } %>
                <h5 class="mb-1"><%= product.name %></h5>
                <p class="text-muted mb-2"><%= product.brand || '' %> <%= product.model || '' %></p>
                <span class="badge bg-<%= product.quantity > product.min_stock ? 'success' : (product.quantity > 0 ? 'warning' : 'danger') %> mb-2">
                    <%= product.quantity > 0 ? (product.quantity <= product.min_stock ? 'Low Stock' : 'In Stock') : 'Out of Stock' %>
                </span>
                <div class="mt-2">
                    <span class="badge bg-light text-dark border"><%= product.category_name || 'Uncategorized' %></span>
                </div>
            </div>
        </div>
    </div>

    <!-- Product Details -->
    <div class="col-lg-8">
        <div class="card mb-4">
            <div class="card-header bg-primary text-white">
                <h6 class="mb-0"><i class="fas fa-info-circle me-2"></i>Product Information</h6>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="text-muted" style="font-size: 12px;">SKU</label>
                        <div class="fw-medium"><code><%= product.sku || 'N/A' %></code></div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="text-muted" style="font-size: 12px;">Barcode</label>
                        <div class="fw-medium"><%= product.barcode || 'N/A' %></div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="text-muted" style="font-size: 12px;">HSN Code</label>
                        <div class="fw-medium"><%= product.hsn_code || 'N/A' %></div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="text-muted" style="font-size: 12px;">GST Rate</label>
                        <div class="fw-medium"><%= product.gst_rate || 18 %>%</div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="text-muted" style="font-size: 12px;">Unit</label>
                        <div class="fw-medium"><%= product.unit || 'piece' %></div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="text-muted" style="font-size: 12px;">Min Stock Level</label>
                        <div class="fw-medium"><%= product.min_stock || 5 %></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Pricing -->
        <div class="card mb-4">
            <div class="card-header bg-success text-white">
                <h6 class="mb-0"><i class="fas fa-rupee-sign me-2"></i>Pricing</h6>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="text-muted" style="font-size: 12px;">Purchase Price</label>
                        <div class="fw-bold text-primary fs-5">₹<%= parseFloat(product.purchase_price).toLocaleString('en-IN', {minimumFractionDigits: 2}) %></div>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="text-muted" style="font-size: 12px;">Selling Price</label>
                        <div class="fw-bold text-success fs-5">₹<%= parseFloat(product.selling_price).toLocaleString('en-IN', {minimumFractionDigits: 2}) %></div>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="text-muted" style="font-size: 12px;">MRP</label>
                        <div class="fw-bold text-dark fs-5">
                            <% if (product.mrp) { %>
                            ₹<%= parseFloat(product.mrp).toLocaleString('en-IN', {minimumFractionDigits: 2}) %>
                            <% } else { %>
                            <span class="text-muted">Not set</span>
                            <% } %>
                        </div>
                    </div>
                </div>
                <% if (product.mrp && product.mrp > product.selling_price) { %>
                <div class="alert alert-info mb-0">
                    <i class="fas fa-tag me-2"></i>
                    Discount: <strong>₹<%= parseFloat(product.mrp - product.selling_price).toLocaleString('en-IN', {minimumFractionDigits: 2}) %></strong> 
                    (<%= Math.round(((product.mrp - product.selling_price) / product.mrp) * 100) %>% off)
                </div>
                <% } %>
            </div>
        </div>

        <!-- Stock -->
        <div class="card mb-4">
            <div class="card-header bg-<%= product.quantity <= 0 ? 'danger' : (product.quantity <= product.min_stock ? 'warning' : 'info') %> text-white">
                <h6 class="mb-0"><i class="fas fa-boxes me-2"></i>Stock Information</h6>
            </div>
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <label class="text-muted" style="font-size: 12px;">Current Quantity</label>
                        <div class="fw-bold fs-2 <%= product.quantity <= 0 ? 'text-danger' : (product.quantity <= product.min_stock ? 'text-warning' : 'text-success') %>">
                            <%= product.quantity %>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <% if (product.quantity <= 0) { %>
                        <div class="alert alert-danger mb-0">
                            <i class="fas fa-times-circle me-2"></i>Out of Stock — Restock immediately
                        </div>
                        <% } else if (product.quantity <= product.min_stock) { %>
                        <div class="alert alert-warning mb-0">
                            <i class="fas fa-exclamation-triangle me-2"></i>Low Stock — Only <%= product.quantity %> left
                        </div>
                        <% } else { %>
                        <div class="alert alert-success mb-0">
                            <i class="fas fa-check-circle me-2"></i>Stock level is healthy
                        </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <!-- Description -->
        <% if (product.description) { %>
        <div class="card mb-4">
            <div class="card-header bg-secondary text-white">
                <h6 class="mb-0"><i class="fas fa-align-left me-2"></i>Description</h6>
            </div>
            <div class="card-body">
                <p class="mb-0"><%= product.description %></p>
            </div>
        </div>
        <% } %>

        <!-- Specifications -->
        <% if (product.specifications) { %>
        <div class="card mb-4">
            <div class="card-header bg-dark text-white">
                <h6 class="mb-0"><i class="fas fa-cogs me-2"></i>Specifications</h6>
            </div>
            <div class="card-body">
                <% try { 
                    const specs = JSON.parse(product.specifications);
                    if (typeof specs === 'object' && specs !== null) { %>
                <div class="row">
                    <% Object.entries(specs).forEach(([key, value]) => { %>
                    <div class="col-md-6 mb-2">
                        <label class="text-muted" style="font-size: 12px;"><%= key %></label>
                        <div class="fw-medium"><%= value %></div>
                    </div>
                    <% }) %>
                </div>
                <% } else { %>
                <pre class="mb-0"><%= product.specifications %></pre>
                <% } 
                } catch(e) { %>
                <pre class="mb-0"><%= product.specifications %></pre>
                <% } %>
            </div>
        </div>
        <% } %>
    </div>
</div>

<%- include('../partials/footer') %>