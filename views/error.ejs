<!DOCTYPE html>
<html>
<head>
    <title>Error</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { display: flex; align-items: center; justify-content: center; min-height: 100vh; background: #f1f5f9; }
        .error-box { text-align: center; padding: 40px; max-width: 500px; }
    </style>
</head>
<body>
    <div class="error-box">
        <i class="fas fa-exclamation-triangle fa-4x text-danger mb-3"></i>
        <h3 class="mb-3">Something Went Wrong</h3>
        <p class="text-muted mb-4"><%= message %></p>
        <a href="/" class="btn btn-primary"><i class="fas fa-home me-2"></i>Go to Dashboard</a>
    </div>
</body>
</html>