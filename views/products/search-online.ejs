<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="mb-1"><i class="fas fa-globe me-2"></i>Search Products Online</h5>
        <p class="text-muted mb-0" style="font-size: 13px;">Import products from Khosla, Flipkart, Amazon</p>
    </div>
    <a href="/products" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-2"></i>Back to Products
    </a>
</div>

<!-- Stats Bar -->
<div class="card bg-gradient-primary text-white mb-4" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
    <div class="card-body py-3">
        <div class="row text-center">
            <div class="col-md-3">
                <h5 class="mb-0"><i class="fas fa-database me-1"></i><span id="db-count">Loading...</span></h5>
                <small>Products in DB</small>
            </div>
            <div class="col-md-3">
                <h5 class="mb-0"><i class="fas fa-barcode me-1"></i><span id="barcode-count">Loading...</span></h5>
                <small>Barcodes Tracked</small>
            </div>
            <div class="col-md-3">
                <h5 class="mb-0"><i class="fas fa-shopping-cart me-1"></i>3 Sites</h5>
                <small>Khosla + Flipkart + Amazon</small>
            </div>
            <div class="col-md-3">
                <h5 class="mb-0"><i class="fas fa-check-double me-1"></i>Auto-Check</h5>
                <small>Duplicate Prevention</small>
            </div>
        </div>
    </div>
</div>

<!-- Search Form -->
<div class="card mb-4">
    <div class="card-body">
        <form id="search-form" action="/products/search-online" method="GET">
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="input-group input-group-lg">
                        <span class="input-group-text bg-primary text-white"><i class="fas fa-search"></i></span>
                        <input type="text" name="q" id="search-input" class="form-control" 
                               placeholder="Search for home appliances... (e.g., mixer grinder, induction cooktop)"
                               value="<%= query %>">
                    </div>
                </div>
                <div class="col-md-3">
                    <select name="platform" id="platform-select" class="form-select form-select-lg">
                        <option value="all" <%= platform === 'all' ? 'selected' : '' %>>All Platforms</option>
                        <option value="khosla" <%= platform === 'khosla' ? 'selected' : '' %>>Khosla Online</option>
                        <option value="flipkart" <%= platform === 'flipkart' ? 'selected' : '' %>>Flipkart</option>
                        <option value="amazon" <%= platform === 'amazon' ? 'selected' : '' %>>Amazon India</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary btn-lg w-100" id="search-btn">
                        <i class="fas fa-search me-1"></i>Search
                    </button>
                </div>
            </div>
        </form>

        <!-- Quick Search Tags -->
        <div class="mt-3">
            <small class="text-muted me-2">Quick Search:</small>
            <button class="btn btn-sm btn-outline-secondary me-1 mb-1 quick-search" data-query="mixer grinder">Mixer Grinder</button>
            <button class="btn btn-sm btn-outline-secondary me-1 mb-1 quick-search" data-query="induction cooktop">Induction Cooktop</button>
            <button class="btn btn-sm btn-outline-secondary me-1 mb-1 quick-search" data-query="water heater">Water Heater</button>
            <button class="btn btn-sm btn-outline-secondary me-1 mb-1 quick-search" data-query="ceiling fan">Ceiling Fan</button>
            <button class="btn btn-sm btn-outline-secondary me-1 mb-1 quick-search" data-query="iron press">Iron Press</button>
            <button class="btn btn-sm btn-outline-secondary me-1 mb-1 quick-search" data-query="toaster">Toaster</button>
            <button class="btn btn-sm btn-outline-secondary me-1 mb-1 quick-search" data-query="electric kettle">Electric Kettle</button>
            <button class="btn btn-sm btn-outline-secondary me-1 mb-1 quick-search" data-query="rice cooker">Rice Cooker</button>
        </div>
    </div>
</div>

<!-- Loading Indicator -->
<div class="text-center py-5" id="loading-indicator" style="display: none;">
    <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
    <p class="mt-3 text-muted">Searching across platforms... This may take 10-30 seconds</p>
</div>

<!-- FIX: Search Results Section -->
<% if (query) { %>
    <% 
    const totalResults = results.khosla.length + results.flipkart.length + results.amazon.length;
    %>

    <% if (totalResults > 0) { %>
    <!-- Results Found -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0"><i class="fas fa-search-results me-2"></i>Search Results for "<%= query %>"</h5>
        <span class="badge bg-primary"><%= totalResults %> products found</span>
    </div>

    <!-- Khosla Results -->
    <% if (results.khosla.length > 0 && (platform === 'all' || platform === 'khosla')) { %>
    <div class="card mb-4 border-primary">
        <div class="card-header bg-primary text-white">
            <i class="fas fa-store me-2"></i>Khosla Online <span class="badge bg-light text-primary ms-2"><%= results.khosla.length %></span>
        </div>
        <div class="card-body">
            <div class="row">
                <% results.khosla.forEach(product => { %>
                <div class="col-md-4 col-lg-3 mb-3">
                    <div class="card h-100 product-card">
                        <img src="<%= product.image %>" class="card-img-top" alt="<%= product.name %>" style="height: 180px; object-fit: cover;">
                        <div class="card-body">
                            <h6 class="card-title" style="font-size: 14px;"><%= product.name %></h6>
                            <p class="text-muted mb-1" style="font-size: 12px;"><%= product.brand %> <%= product.model %></p>
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="fw-bold text-primary">₹<%= product.price.toLocaleString('en-IN') %></span>
                                    <small class="text-muted text-decoration-line-through ms-1">₹<%= product.mrp.toLocaleString('en-IN') %></small>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-transparent">
                            <button class="btn btn-sm btn-success w-100" onclick="fillImportForm('<%= product.name.replace(/'/g, "\\'") %>', '<%= product.brand %>', '<%= product.model %>', <%= product.price %>, <%= product.mrp %>)" style="font-size: 12px;">
                                <i class="fas fa-download me-1"></i>Import
                            </button>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>
        </div>
    </div>
    <% } %>

    <!-- Flipkart Results -->
    <% if (results.flipkart.length > 0 && (platform === 'all' || platform === 'flipkart')) { %>
    <div class="card mb-4 border-warning">
        <div class="card-header bg-warning text-dark">
            <i class="fas fa-shopping-bag me-2"></i>Flipkart <span class="badge bg-light text-warning ms-2"><%= results.flipkart.length %></span>
        </div>
        <div class="card-body">
            <div class="row">
                <% results.flipkart.forEach(product => { %>
                <div class="col-md-4 col-lg-3 mb-3">
                    <div class="card h-100 product-card">
                        <img src="<%= product.image %>" class="card-img-top" alt="<%= product.name %>" style="height: 180px; object-fit: cover;">
                        <div class="card-body">
                            <h6 class="card-title" style="font-size: 14px;"><%= product.name %></h6>
                            <p class="text-muted mb-1" style="font-size: 12px;"><%= product.brand %> <%= product.model %></p>
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="fw-bold text-primary">₹<%= product.price.toLocaleString('en-IN') %></span>
                                    <small class="text-muted text-decoration-line-through ms-1">₹<%= product.mrp.toLocaleString('en-IN') %></small>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-transparent">
                            <button class="btn btn-sm btn-success w-100" onclick="fillImportForm('<%= product.name.replace(/'/g, "\\'") %>', '<%= product.brand %>', '<%= product.model %>', <%= product.price %>, <%= product.mrp %>)" style="font-size: 12px;">
                                <i class="fas fa-download me-1"></i>Import
                            </button>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>
        </div>
    </div>
    <% } %>

    <!-- Amazon Results -->
    <% if (results.amazon.length > 0 && (platform === 'all' || platform === 'amazon')) { %>
    <div class="card mb-4 border-info">
        <div class="card-header bg-info text-white">
            <i class="fab fa-amazon me-2"></i>Amazon India <span class="badge bg-light text-info ms-2"><%= results.amazon.length %></span>
        </div>
        <div class="card-body">
            <div class="row">
                <% results.amazon.forEach(product => { %>
                <div class="col-md-4 col-lg-3 mb-3">
                    <div class="card h-100 product-card">
                        <img src="<%= product.image %>" class="card-img-top" alt="<%= product.name %>" style="height: 180px; object-fit: cover;">
                        <div class="card-body">
                            <h6 class="card-title" style="font-size: 14px;"><%= product.name %></h6>
                            <p class="text-muted mb-1" style="font-size: 12px;"><%= product.brand %> <%= product.model %></p>
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="fw-bold text-primary">₹<%= product.price.toLocaleString('en-IN') %></span>
                                    <small class="text-muted text-decoration-line-through ms-1">₹<%= product.mrp.toLocaleString('en-IN') %></small>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-transparent">
                            <button class="btn btn-sm btn-success w-100" onclick="fillImportForm('<%= product.name.replace(/'/g, "\\'") %>', '<%= product.brand %>', '<%= product.model %>', <%= product.price %>, <%= product.mrp %>)" style="font-size: 12px;">
                                <i class="fas fa-download me-1"></i>Import
                            </button>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>
        </div>
    </div>
    <% } %>
    <% } else { %>
    <!-- No Results -->
    <div class="alert alert-warning">
        <i class="fas fa-exclamation-circle me-2"></i>
        No products found for "<%= query %>". Try a different search term or use the manual import form below.
    </div>
    <% } %>

    <!-- Manual Import Form -->
    <div class="card">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0"><i class="fas fa-download me-2"></i>Import Product Manually</h5>
        </div>
        <div class="card-body">
            <form id="import-form">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <input type="hidden" name="source_platform" value="manual">

                <div class="row">
                    <div class="col-md-8">
                        <div class="mb-3">
                            <label class="form-label">Product Name *</label>
                            <input type="text" name="name" id="import-name" class="form-control" required 
                                   value="<%= query %>">
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Brand</label>
                                <input type="text" name="brand" id="import-brand" class="form-control">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Model</label>
                                <input type="text" name="model" id="import-model" class="form-control">
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Barcode</label>
                            <input type="text" name="barcode" id="import-barcode" class="form-control" 
                                   placeholder="Scan or enter barcode">
                            <div class="form-text">Checked for duplicates automatically</div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">SKU (Auto-generated if empty)</label>
                            <input type="text" name="sku" id="import-sku" class="form-control">
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Category</label>
                        <select name="category_id" id="import-category" class="form-select">
                            <option value="">Select Category</option>
                            <% 
                            const seenCats = new Set();
                            categories.forEach(cat => {
                                if (cat.name && !seenCats.has(cat.name)) {
                                    seenCats.add(cat.name);
                            %>
                            <option value="<%= cat.id %>"><%= cat.name %></option>
                            <% 
                                }
                            }); 
                            %>
                        </select>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">HSN Code</label>
                        <input type="text" name="hsn_code" id="import-hsn" class="form-control" placeholder="e.g. 8415">
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">GST Rate (%)</label>
                        <select name="gst_rate" id="import-gst" class="form-select">
                            <option value="5">5%</option>
                            <option value="12">12%</option>
                            <option value="18" selected>18%</option>
                            <option value="28">28%</option>
                        </select>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Purchase Price *</label>
                        <div class="input-group">
                            <span class="input-group-text">&#8377;</span>
                            <input type="number" name="purchase_price" id="import-purchase-price" class="form-control" step="0.01" required>
                        </div>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Selling Price *</label>
                        <div class="input-group">
                            <span class="input-group-text">&#8377;</span>
                            <input type="number" name="selling_price" id="import-selling-price" class="form-control" step="0.01" required>
                        </div>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">MRP</label>
                        <div class="input-group">
                            <span class="input-group-text">&#8377;</span>
                            <input type="number" name="mrp" id="import-mrp" class="form-control" step="0.01">
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <textarea name="description" id="import-description" class="form-control" rows="2"></textarea>
                </div>

                <div class="alert alert-warning" id="duplicate-alert" style="display: none;">
                    <i class="fas fa-exclamation-triangle me-1"></i>
                    <span id="duplicate-message"></span>
                </div>

                <button type="button" class="btn btn-success" id="import-btn" onclick="importProduct()">
                    <i class="fas fa-save me-1"></i>Import to Database
                </button>
            </form>
        </div>
    </div>
<% } else { %>
    <!-- Empty State -->
    <div class="text-center py-5">
        <i class="fas fa-globe fa-4x text-muted mb-3"></i>
        <h4 class="text-muted">Search Products from Indian E-commerce Sites</h4>
        <p class="text-muted">Enter a product name above to search Khosla Online, Flipkart, and Amazon</p>
        <div class="mt-4">
            <div class="row justify-content-center">
                <div class="col-md-4 mb-3">
                    <div class="card border-primary">
                        <div class="card-body">
                            <i class="fas fa-store fa-2x text-primary mb-2"></i>
                            <h6>Khosla Online</h6>
                            <small class="text-muted">Home appliances & electronics</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 mb-3">
                    <div class="card border-warning">
                        <div class="card-body">
                            <i class="fas fa-shopping-bag fa-2x text-warning mb-2"></i>
                            <h6>Flipkart</h6>
                            <small class="text-muted">Wide range of products</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 mb-3">
                    <div class="card border-info">
                        <div class="card-body">
                            <i class="fab fa-amazon fa-2x text-info mb-2"></i>
                            <h6>Amazon India</h6>
                            <small class="text-muted">Global marketplace</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
<% } %>

<!-- Toast Container -->
<div class="toast-container position-fixed bottom-0 end-0 p-3" id="toast-container"></div>

<%- include('../partials/footer') %>

<script>
    // Load database stats
    fetch('/api/products/stats')
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                document.getElementById('db-count').textContent = data.totalProducts || 0;
                document.getElementById('barcode-count').textContent = data.totalBarcodes || 0;
            }
        })
        .catch(err => console.error('Stats error:', err));

    // Quick search buttons
    document.querySelectorAll('.quick-search').forEach(btn => {
        btn.addEventListener('click', function() {
            document.getElementById('search-input').value = this.dataset.query;
            document.getElementById('search-form').submit();
        });
    });

    // Show loading on search
    document.getElementById('search-form').addEventListener('submit', function() {
        document.getElementById('loading-indicator').style.display = 'block';
    });

    // FIX: Fill import form from search result card
    function fillImportForm(name, brand, model, price, mrp) {
        document.getElementById('import-name').value = name;
        document.getElementById('import-brand').value = brand;
        document.getElementById('import-model').value = model;
        document.getElementById('import-selling-price').value = price;
        document.getElementById('import-mrp').value = mrp;
        // Auto-calculate purchase price as 70% of selling price
        document.getElementById('import-purchase-price').value = Math.round(price * 0.7);

        // Scroll to import form
        document.getElementById('import-form').scrollIntoView({ behavior: 'smooth', block: 'center' });
        showToast('Product details filled. Adjust prices and click Import.', 'info');
    }

    // Import product function
    function importProduct() {
        const form = document.getElementById('import-form');
        const formData = new FormData(form);
        const data = Object.fromEntries(formData);

        // Validate
        if (!data.name || !data.purchase_price || !data.selling_price) {
            showToast('Please fill in Name, Purchase Price, and Selling Price', 'danger');
            return;
        }

        const btn = document.getElementById('import-btn');
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Importing...';

        fetch('/products/import-from-online', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRF-Token': data._csrf
            },
            body: JSON.stringify(data)
        })
        .then(res => res.json())
        .then(result => {
            if (result.success) {
                showToast('Product imported! SKU: ' + result.sku, 'success');
                // Reset form
                form.reset();
                document.getElementById('import-name').value = '';
                document.getElementById('duplicate-alert').style.display = 'none';
                // Reload stats
                loadStats();
            } else if (result.duplicate) {
                showToast('Duplicate: ' + result.message, 'warning');
                const alert = document.getElementById('duplicate-alert');
                alert.style.display = 'block';
                alert.className = 'alert alert-warning';
                document.getElementById('duplicate-message').innerHTML = 
                    result.message + ' <a href="/products/edit/' + result.productId + '" class="alert-link">Edit Product</a>';
            } else {
                showToast(result.message, 'danger');
            }
        })
        .catch(err => {
            console.error('Import error:', err);
            showToast('Error importing product', 'danger');
        })
        .finally(() => {
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-save me-1"></i>Import to Database';
        });
    }

    // Check duplicate on barcode blur
    document.getElementById('import-barcode').addEventListener('blur', function() {
        const barcode = this.value;
        if (!barcode) return;

        fetch('/products/check-duplicate?barcode=' + encodeURIComponent(barcode))
            .then(res => res.json())
            data => {
                const alert = document.getElementById('duplicate-alert');
                if (data.exists) {
                    alert.style.display = 'block';
                    alert.className = 'alert alert-warning';
                    document.getElementById('duplicate-message').innerHTML = 
                        'Product with barcode "' + barcode + '" already exists: ' + data.product.name + 
                        ' <a href="/products/edit/' + data.product.id + '" class="alert-link">Edit</a>';
                } else {
                    alert.style.display = 'none';
                }
            })
            .catch(err => console.error('Duplicate check error:', err));
    });

    function loadStats() {
        fetch('/api/products/stats')
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    document.getElementById('db-count').textContent = data.totalProducts || 0;
                    document.getElementById('barcode-count').textContent = data.totalBarcodes || 0;
                }
            })
            .catch(err => console.error('Stats error:', err));
    }

    function showToast(message, type) {
        const container = document.getElementById('toast-container');
        const toast = document.createElement('div');
        toast.className = `toast align-items-center text-white bg-${type} border-0`;
        toast.setAttribute('role', 'alert');
        toast.innerHTML = `
            <div class="d-flex">
                <div class="toast-body">${message}</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        `;
        container.appendChild(toast);
        const bsToast = new bootstrap.Toast(toast, { delay: 5000 });
        bsToast.show();
        toast.addEventListener('hidden.bs.toast', () => toast.remove());
    }
</script>